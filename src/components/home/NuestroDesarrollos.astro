---
import { Image } from "astro:assets";
import { desarrollos } from "@/constants/home";
import SectionHeading from "@/components/shared/SectionHeading.astro";
import ScrollReveal from "@/components/shared/ScrollReveal";
---

<section class="mx-auto max-w-7xl px-5 py-20 md:px-8 md:py-28">
  <SectionHeading
    title="Nuestros Desarrollos"
    eyebrow="Portafolio"
    align="center"
  />

  <div class="relative mt-14 grid gap-6 md:grid-cols-3">
    {
      desarrollos.map((item, index) => (
        <ScrollReveal client:visible delay={index * 0.1}>
          <div class="group flex h-full flex-col overflow-hidden rounded-2xl border border-line bg-panel transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            {/* Image Container */}
            <div class="relative flex aspect-4/2 items-center justify-center bg-white p-8 overflow-hidden">
              <Image
                src={item.image.image}
                alt={item.title}
                width={450}
                height={300}
                class="max-h-full max-w-full object-contain transition-transform duration-700 ease-out group-hover:scale-105"
              />
            </div>

            {/* Text Content */}
            <div class="flex flex-1 flex-col justify-start p-6 md:p-8">
              <h3 class="font-display text-xl font-medium text-ink md:text-2xl">
                {item.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-muted">
                {item.description}
              </p>
            </div>
          </div>
        </ScrollReveal>
      ))
    }
  </div>

  {/* Button below the grid */}
  <div class="mt-12 flex justify-center">
    <a
      href="/propiedades"
      class="rounded-full bg-secondary px-8 py-4 text-xs font-semibold uppercase tracking-widest text-[#1c1606] shadow-xl transition-transform hover:-translate-y-1"
    >
      Ver propiedades
    </a>
  </div>
</section>
